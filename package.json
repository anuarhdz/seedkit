{
  "name": "seedkit",
  "version": "0.0.0",
  "private": true,
  "author": "Anuar Reyes <anuar@hey.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/anuarhdz/seedkit"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "generate": "pnpm --filter @seedkit/generate dev",
    "scrape": "pnpm --filter @seedkit/scrape scrape",
    "transform": "pnpm --filter @seedkit/transform transform",
    "release": "release-it",
    "release:patch": "release-it patch",
    "release:minor": "release-it minor",
    "release:major": "release-it major"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.17.0",
    "@release-it/conventional-changelog": "^10.0.6",
    "@types/node": "^22.10.7",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "release-it": "^19.2.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.0"
  },
  "lint-staged": {
    "*.{ts,mts,cts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  }
}
