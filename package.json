{
  "name": "seedkit",
  "version": "0.0.1",
  "description": "CLI tools for generating and transforming MDX demo content",
  "author": "Anuar Reyes <anuar@hey.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/anuarhdz/seedkit"
  },
  "homepage": "https://github.com/anuarhdz/seedkit",
  "keywords": [
    "mdx",
    "cli",
    "content",
    "generate",
    "scrape",
    "transform",
    "demo",
    "faker"
  ],
  "files": [
    "README.md"
  ],
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "typecheck": "pnpm -r run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "generate": "pnpm --filter @seedkit/generate dev",
    "scrape": "pnpm --filter @seedkit/scrape scrape",
    "transform": "pnpm --filter @seedkit/transform transform",
    "release": "release-it",
    "release:patch": "release-it patch",
    "release:minor": "release-it minor",
    "release:major": "release-it major"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.17.0",
    "@release-it/conventional-changelog": "^8.0.2",
    "@types/node": "^22.10.7",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "release-it": "^17.11.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.0"
  },
  "lint-staged": {
    "*.{ts,mts,cts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  }
}
