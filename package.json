{
  "name": "seedkit",
  "version": "0.1.3",
  "description": "CLI tools for generating and transforming MDX demo content",
  "author": "Anuar Reyes <anuar@hey.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/anuarhdz/seedkit"
  },
  "homepage": "https://github.com/anuarhdz/seedkit",
  "keywords": [
    "mdx",
    "cli",
    "content",
    "generate",
    "scrape",
    "transform",
    "demo",
    "faker"
  ],
  "files": [
    "README.md",
    "dist"
  ],
  "bin": {
    "seedkit": "./dist/cli.js"
  },
  "exports": {
    "./generate": {
      "types": "./dist/generate-api.d.ts",
      "default": "./dist/generate-api.js"
    },
    "./scrape": {
      "types": "./dist/scrape-api.d.ts",
      "default": "./dist/scrape-api.js"
    },
    "./transform": {
      "types": "./dist/transform-api.d.ts",
      "default": "./dist/transform-api.js"
    }
  },
  "type": "module",
  "scripts": {
    "build": "tsup",
    "build:packages": "pnpm -r run build",
    "typecheck": "tsc --noEmit && pnpm -r run typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "generate": "pnpm --filter @seedkit/generate dev",
    "scrape": "pnpm --filter @seedkit/scrape scrape",
    "transform": "pnpm --filter @seedkit/transform transform",
    "release": "release-it",
    "release:patch": "release-it patch",
    "release:minor": "release-it minor",
    "release:major": "release-it major"
  },
  "dependencies": {
    "jiti": "^2.6.1",
    "@faker-js/faker": "^10.0.0",
    "node-html-parser": "^6.1.13",
    "turndown": "^7.2.0",
    "glob": "^11.0.0",
    "js-yaml": "^4.1.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.0",
    "@commitlint/config-conventional": "^19.6.0",
    "@eslint/js": "^9.17.0",
    "@release-it/conventional-changelog": "^8.0.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.7",
    "@types/turndown": "^5.0.6",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "release-it": "^17.11.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.19.0"
  },
  "lint-staged": {
    "*.{ts,mts,cts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  }
}
